#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('locallibrary:server');
var http = require('http');

/**
 * Get port from environment and store in Express.
 */
var DEFAULT_PORT = 3000;
var port = normalizePort(process.env.PORT || DEFAULT_PORT);
app.set('port', port);

/**
 * Create HTTP server.
 */
var server = http.createServer(app);

/**
 * Listen on provided port, on all network interfaces.
 * Если порт занят, ищем следующий свободный порт.
 */
function startServer(currentPort) {
  server.listen(currentPort);
  server.on('error', function(error) {
    if (error.syscall !== 'listen') {
      throw error;
    }
    if (error.code === 'EADDRINUSE') {
      console.warn(`Port ${currentPort} is in use, trying port ${currentPort + 1}...`);
      startServer(currentPort + 1); // пробуем следующий порт
    } else {
      throw error;
    }
  });
  server.on('listening', function() {
    var addr = server.address();
    var bind = typeof addr === 'string' ? 'pipe ' + addr : 'port ' + addr.port;
    debug('Listening on ' + bind);
    console.log(`Server is running on http://localhost:${addr.port}`);
  });
}

startServer(port);

/**
 * Normalize a port into a number, string, or false.
 */
function normalizePort(val) {
  var port = parseInt(val, 10);
  if (isNaN(port)) {
    // named pipe
    return val;
  }
  if (port >= 0) {
    // port number
    return port;
  }
  return false;
}