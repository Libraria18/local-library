extends layout

block content
  h1= title

  form(method='POST')
    .form-group
      label(for='title') Назва:
      input#title.form-control(type='text', placeholder='Назва книги', name='title', required, value=(undefined === book ? '' : book.title))

    .form-group
      label(for='author') Автор:
      select#author.form-control(name='author', required)
        option(value='') --Будь ласка, виберіть автора--
        each author in authors
          if book
            if author._id.toString() === book.author.toString()
              option(value=author._id selected) #{author.name}
            else
              option(value=author._id) #{author.name}
          else
            option(value=author._id) #{author.name}

    .form-group
      label(for='summary') Опис:
      textarea#summary.form-control(placeholder='Опис', name='summary', required)= undefined === book ? '' : book.summary

    .form-group
      label(for='isbn') ISBN:
      input#isbn.form-control(type='text', placeholder='ISBN13', name='isbn', value=(undefined === book ? '' : book.isbn), required)

    .form-group
      label Жанр:
      div
        each genre in genres
          div(style='display: inline; padding-right:10px;')
            if genre.checked
              input.checkbox-input(type='checkbox', name='genre', id=genre._id, value=genre._id, checked)
            else
              input.checkbox-input(type='checkbox', name='genre', id=genre._id, value=genre._id)
            label(for=genre._id) &nbsp;#{genre.name}

    button.btn.btn-primary(type='submit') Зберегти

  if errors
    ul
      each error in errors
        li!= error.msg